# ============================================================
# WildNode AI - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# OpenWeather API Key (free at https://openweathermap.org/api)
# Leave as "MOCK" to use the built-in offline mock
OPENWEATHER_API_KEY=MOCK

# Location for weather data (City name or lat,lon)
WEATHER_LOCATION=Kaziranga

# Alert Settings
ALERT_PHONE_NUMBER=+91XXXXXXXXXX

# Dashboard refresh rate (seconds)
DASHBOARD_REFRESH_SECONDS=3

# Detection Confidence Threshold (0.0 - 1.0)
CONFIDENCE_THRESHOLD=0.55

# Risk Score thresholds
RISK_LOW=30
RISK_MEDIUM=55
RISK_HIGH=75
